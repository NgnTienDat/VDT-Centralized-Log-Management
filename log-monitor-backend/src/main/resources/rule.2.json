{
  "ruleId": "high_error",
  "name": "Count threshold - Too many errors",
  "intervalMinutes": 1,
  "isActive": true,
  "lastRunTime": 0,
  "pipelineSteps": [
    {
      "id": "STEP_1",
      "type": "FETCH_ES_DATA",
      "params": {
        "index": "logs",
        "timeField": "timestamp",
        "lookBackMinutes": 5,
        "query": "level:ERROR or level:CRITICAL"
      }
    },
    {
      "id": "STEP_2",
      "type": "EVALUATE_THRESHOLD",
      "params": {
        "input": "STEP_1",
        "operator": "GREATER_THAN",
        "value": 5
      }
    }
  ]
}