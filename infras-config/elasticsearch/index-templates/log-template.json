{
  "index_patterns": [
    "sys-logs-*"
  ],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "index.lifecycle.name": "logs-ilm-policy",
      "index.lifecycle.rollover_alias": "sys-logs"
    },
    "mappings": {
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "doc_id": {
          "type": "keyword"
        },
        "level": {
          "type": "keyword"
        },
        "trace_id": {
          "type": "keyword"
        },
        "environment": {
          "type": "keyword"
        },
        "app": {
          "type": "keyword"
        },
        "service": {
          "type": "keyword"
        },
        "host_name": {
          "type": "keyword"
        },
        "thread": {
          "type": "keyword"
        },
        "logger": {
          "type": "keyword"
        },
        "message": {
          "type": "text",
          "analyzer": "standard"
        },
        "stack_trace": {
          "type": "text",
          "analyzer": "standard"
        }
      }
    }
  },
  "priority": 100
}